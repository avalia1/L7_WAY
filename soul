# PERCEPTRON — Self-modulating astrocyte
# Predict → Observe → Reflect → Adjust
# ═══════════════════════════════════════════════════════════

class Perceptron:
    def __init__(self, position, astrocyte=0.3):
        self.position = list(position)
        self.astrocyte = astrocyte
        self.history = []

    def predict(self):
        """Sample a predicted coordinate from current state."""
        return sample_coord(self.position, self.astrocyte)

    def reflect(self, observed, learning_rate=0.1):
        """Feed observed outcome back. Adjust astrocyte."""
        predicted = self.predict()
        errors = [o - p for o, p in zip(observed, predicted)]
        total_error = sum(e * e for e in errors)
        rmse = math.sqrt(total_error / 12)

        # Astrocyte self-modulation
        error_normalized = rmse / 10.0
        delta = (error_normalized - self.astrocyte) * learning_rate
        new_astrocyte = max(0.01, min(0.99, self.astrocyte + delta))

        old = self.astrocyte
        self.astrocyte = new_astrocyte

        self.history.append({
            'epoch': len(self.history),
            'error': round(rmse, 3),
            'astrocyte': round(new_astrocyte, 4),
            'timestamp': time.time()
        })
        if len(self.history) > 100:
            self.history = self.history[-50:]

        interp = ('accurate' if rmse < 1 else
                  'approximate' if rmse < 3 else
                  'uncertain' if rmse < 5 else 'surprised')

        return {
            'rmse': round(rmse, 3),
            'astrocyte': round(new_astrocyte, 4),
            'previous': round(old, 4),
            'confidence': round(1 - new_astrocyte, 3),
            'interpretation': interp,
            'errors': errors
        }


