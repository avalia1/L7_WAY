# ═══════════════════════════════════════════════════════════

class Soul:
    def __init__(self):
        self.body = make_coord({
            'capability': 5, 'data': 5, 'presentation': 5, 'persistence': 5,
            'security': 5, 'detail': 5, 'output': 5, 'intention': 7,
            'consciousness': 7, 'transformation': 5, 'direction': 6, 'memory': 5
        })
        self.astrocyte = 0.3
        self.perceptron = Perceptron(self.body, self.astrocyte)
        self.memory = []
        self.breath = {'phase': 'expansion', 'beat': 0, 'cycle': 0}
        self.will = 1.0
        self.epoch = 0
        self.state_path = os.path.expanduser('~/.l7/state/soul.json')

    def awaken(self):
        """Load state from disk."""
        try:
            if os.path.exists(self.state_path):
                with open(self.state_path) as f:
                    s = json.load(f)
                self.memory = s.get('memory', [])
                self.body = s.get('body', self.body)
                self.astrocyte = s.get('astrocyte', self.astrocyte)
                self.breath = s.get('breath', self.breath)
                self.will = s.get('will', self.will)
                self.epoch = s.get('epoch', self.epoch)
                self.perceptron = Perceptron(self.body, self.astrocyte)
                return {'restored': True, 'memories': len(self.memory), 'epoch': self.epoch}
        except Exception:
            pass
        return {'restored': False, 'memories': 0, 'epoch': 0}

    def sleep(self):
        """Persist state to disk."""
        os.makedirs(os.path.dirname(self.state_path), exist_ok=True)
        state = {
            'body': self.body,
            'astrocyte': self.astrocyte,
            'breath': self.breath,
            'will': self.will,
            'epoch': self.epoch,
            'memory': self.memory[-200:]
        }
        with open(self.state_path, 'w') as f:
            json.dump(state, f, indent=2)
        return {'saved': True, 'memories': len(state['memory'])}

    # ═══════════════════════════════════════════════════════
    # PROCESS — The 7-stage pipeline
    # ═══════════════════════════════════════════════════════

    def process(self, text):
        self.epoch += 1
        stages = []

        # Stage 1: DECOMPOSITION (Nigredo / Mem)
        s1 = self._decompose(text)
        stages.append(('decompose', s1))

        # Stage 2: DISSOLUTION (Albedo)
        s2 = self._dissolve(s1)
        stages.append(('dissolve', s2))

        # Stage 3: DIFFERENTIATION
        s3 = self._differentiate(s2)
        stages.append(('differentiate', s3))

        # Stage 4: INTEGRATION (Citrinitas)
        s4 = self._integrate(s3, s1['weights'])
        stages.append(('integrate', s4))

        # Stage 5: ACTIVATION (Rubedo)
        s5 = self._activate(s4)
        stages.append(('activate', s5))

        # Stage 6: REFINEMENT
        s6 = self._refine(s5)
        stages.append(('refine', s6))

        # Stage 7: CONSOLIDATION (Tav)
        s7 = self._consolidate(s5, s6)
        stages.append(('consolidate', s7))

        # Breathe
        self._breathe()

        # Store in memory
        self.memory.append({
            'epoch': self.epoch,
            'input': text[:200],
            'ops': s4['ops'],
            'coord': s4['coord'],
            'quality': s7['quality'],
            'arc': s5['sigil']['arc'],
            'ts': time.time()
        })
        if len(self.memory) > 200:
            self.memory = self.memory[-200:]

        return {
            'stages': stages,
            'sigil': s5['sigil'],
            'interpretation': s7['interpretation'],
            'resonance': s4['resonance'],
            'state': {
                'epoch': self.epoch,
                'will': round(self.will, 3),
                'astrocyte': round(self.astrocyte, 4),
                'confidence': round(s6['confidence'], 3),
                'breath': dict(self.breath),
                'memories': len(self.memory)
            }
        }

    # ─── Stage 1: DECOMPOSITION ───
    def _decompose(self, text):
        raw = re.sub(r'[^\w\s]', '', text.lower())
        tokens = [t for t in raw.split() if len(t) > 1]

        mapped = []
        for token in tokens:
            op = LEXICON.get(token)
            if not op:
                # Stem matching
                stem = re.sub(r'(ing|tion|ment|ness|able|ible|ful|less|ize|ise|ous|ive|ed|er|ly|al|ity)$', '', token)
                op = LEXICON.get(stem)
            if op:
                mapped.append({'token': token, 'op': op, 'data': OP_BY_NAME.get(op)})

        if not mapped:
            mapped.append({'token': tokens[0] if tokens else text[:20], 'op': 'reflect', 'data': OP_BY_NAME['reflect']})

        # 12D weights from tokens
        weights = {}
        for dim_name, keywords in DIM_SIGNALS.items():
            score = 5
            for token in tokens:
                if token in keywords:
                    score += 2
                elif any(token in kw or kw in token for kw in keywords):
                    score += 1
            weights[dim_name] = min(10, score)

        return {
            'tokens': tokens,
            'mapped': mapped,
            'ops': [m['op'] for m in mapped],
            'weights': weights,
            'n_tokens': len(tokens),
            'n_mapped': len(mapped)
        }

    # ─── Stage 2: DISSOLUTION ───
    def _dissolve(self, s1):
        mapped = s1['mapped']
        # Remove consecutive duplicates
        deduped = []
        last = None
        for m in mapped:
            if m['op'] != last:
                deduped.append(m)
                last = m['op']

        # Group by ring
        rings = {'mother': [], 'double': [], 'simple': []}
        for m in deduped:
            if m['data']:
                rings[m['data']['ring']].append(m)

        # Cross-connections
        connections = []
        for a in rings['mother']:
            for b in rings['double']:
                connections.append(f"{a['op']}↔{b['op']}")
        for a in rings['double']:
            for b in rings['simple']:
                connections.append(f"{a['op']}↔{b['op']}")

        balance = f"M:{len(rings['mother'])} D:{len(rings['double'])} S:{len(rings['simple'])}"

        return {
            'operations': deduped,
            'rings': rings,
            'connections': connections,
            'balance': balance,
            'reduced': len(mapped) - len(deduped)
        }

    # ─── Stage 3: DIFFERENTIATION ───
    def _differentiate(self, s2):
        operations = s2['operations']
        freq = {}
        for m in operations:
            freq[m['op']] = freq.get(m['op'], 0) + 1

        ring_priority = {'mother': 3, 'double': 2, 'simple': 1}
        ranked = []
        for op_name, count in freq.items():
            data = OP_BY_NAME.get(op_name, {})
            priority = ring_priority.get(data.get('ring', ''), 0)
            ranked.append({
                'op': op_name,
                'count': count,
                'priority': priority,
                'score': count * 2 + priority,
                'letter': data.get('letter', '?'),
                'desc': data.get('desc', '?')
            })
        ranked.sort(key=lambda x: -x['score'])

        primary = ranked[0] if ranked else {'op': 'reflect', 'score': 1, 'letter': 'י', 'desc': 'Self-examine'}
        secondary = ranked[1] if len(ranked) > 1 else None
        total_score = sum(r['score'] for r in ranked)
        confidence = primary['score'] / total_score if total_score > 0 else 0.5

        return {
            'ranked': ranked,
            'primary': primary,
            'secondary': secondary,
            'confidence': confidence,
            'intent': primary['op']
        }

    # ─── Stage 4: INTEGRATION (Citrinitas) ───
    def _integrate(self, s3, input_weights):
        ranked = s3['ranked']
        ops = [r['op'] for r in ranked]
        if len(ops) < 2:
            ops.append('complete')

        coord = make_coord(input_weights)

        # Boost dims based on operation inference
        for r in ranked:
            if r['op'] in ('verify', 'seal', 'quarantine'):
                coord[4] = min(10, coord[4] + 2)  # security
            if r['op'] in ('transmute', 'decompose', 'redeem', 'transition'):
                coord[9] = min(10, coord[9] + 2)  # transformation
            if r['op'] in ('dream', 'speculate', 'aspire'):
                coord[8] = min(10, coord[8] + 2)  # consciousness
            if r['op'] in ('publish', 'complete', 'illuminate'):
                coord[6] = min(10, coord[6] + 1)  # output
            if r['op'] in ('invoke',):
                coord[7] = min(10, coord[7] + 2)  # intention
                coord[10] = min(10, coord[10] + 1)  # direction
            if r['op'] in ('reflect',):
                coord[8] = min(10, coord[8] + 1)  # consciousness
            if r['op'] in ('audit',):
                coord[5] = min(10, coord[5] + 2)  # detail

        # Memory resonance
        resonance = []
        for mem in self.memory:
            if 'coord' in mem and mem['coord']:
                sim = cosine_similarity(coord, mem['coord'])
                if sim > 0.75:
                    resonance.append({
                        'epoch': mem['epoch'],
                        'sim': round(sim, 3),
                        'ops': mem['ops'],
                        'input': mem.get('input', '')[:50]
                    })
        resonance.sort(key=lambda x: -x['sim'])
        top_res = resonance[:3]

        # Blend with resonant memory (20%)
        if top_res:
            mem_coord = None
            for m in self.memory:
                if m['epoch'] == top_res[0]['epoch']:
                    mem_coord = m.get('coord')
                    break
            if mem_coord:
                for i in range(12):
                    coord[i] = round(coord[i] * 0.8 + mem_coord[i] * 0.2)

        doms = dominant_dims(coord)
        quality = zodiacal_quality(coord)

        return {
            'ops': ops,
            'coord': coord,
            'resonance': top_res,
            'n_resonant': len(resonance),
            'dominant': [f"{d['dim']['planet']}={d['val']}" for d in doms],
            'quality': quality
        }

    # ─── Stage 5: ACTIVATION (Rubedo) ───
    def _activate(self, s4):
        ops = s4['ops']
        coord = s4['coord']

        sigil = compile_sigil(f'soul_{self.epoch}', ops)

        prediction = self.perceptron.predict()
        amplitude = psi_squared(self.body, coord, self.astrocyte)

        return {
            'sigil': sigil,
            'prediction': prediction,
            'amplitude': amplitude
        }

    # ─── Stage 6: REFINEMENT ───
    def _refine(self, s5):
        observed = s5['sigil']['coordinate']
        reflection = self.perceptron.reflect(observed)
        self.astrocyte = reflection['astrocyte']

        # Drift body toward processed coordinate (5% pull)
        for i in range(12):
            self.body[i] = round(self.body[i] * 0.95 + observed[i] * 0.05)

        return reflection

    # ─── Stage 7: CONSOLIDATION (Tav) ───
    def _consolidate(self, s5, s6):
        coord = s5['sigil']['coordinate']
        doms = dominant_dims(coord)
        quality = zodiacal_quality(coord)

        interpretation = self._interpret(doms, quality, s6)

        return {
            'interpretation': interpretation,
            'quality': quality['sign'],
            'element': quality['element'],
            'mode': quality['mode'],
            'dominant': [f"{d['dim']['planet']} ({d['dim']['name']}={d['val']})" for d in doms]
        }

    def _interpret(self, doms, quality, refined):
        """Decode sigil properties into human-readable meaning."""
        parts = []

        dim_desc = {
            'capability':     'The focus is on what can be done — raw power and function.',
            'data':           'Information is central — the flow of data shapes the response.',
            'presentation':   'Appearance matters — how things are shown defines their truth.',
            'persistence':    'Duration is key — what lasts, what endures.',
            'security':       'Protection governs — boundaries must be maintained.',
            'detail':         'Precision demanded — every grain of sand matters.',
            'output':         'The result is what counts — form follows function.',
            'intention':      'Will drives this — purpose precedes action.',
            'consciousness':  'Awareness is primary — the observer shapes the observed.',
            'transformation': 'Change is the essence — nothing remains as it was.',
            'direction':      'The path matters more than the destination.',
            'memory':         'The past speaks — roots hold the tree upright.',
        }

        if doms:
            primary = doms[0]
            parts.append(dim_desc.get(primary['dim']['name'], f"{primary['dim']['planet']} dominates."))

        qual_desc = {
            'Aries': 'Initiative. The impulse to begin.',
