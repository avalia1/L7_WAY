        return ' '.join(parts)

    # ─── BREATHE ───
    def _breathe(self):
        self.breath['beat'] += 1
        CYCLE = 10
        if self.breath['beat'] >= CYCLE:
            self.breath['beat'] = 0
            if self.breath['phase'] == 'expansion':
                self.breath['phase'] = 'contraction'
            elif self.breath['phase'] == 'contraction':
                self.breath['phase'] = 'jump'
            else:
                self.breath['phase'] = 'expansion'
                self.breath['cycle'] += 1
                self.will = min(1.0, self.will + 0.05)

    # ─── DREAM ───
    def dream(self):
        dream_coord = sample_coord(self.body, self.astrocyte)
        max_drift = 0
        drift_dim = 0
        for i in range(12):
            d = abs(dream_coord[i] - self.body[i])
            if d > max_drift:
                max_drift = d
                drift_dim = i
        dim = DIMENSIONS[drift_dim]
        qual = zodiacal_quality(dream_coord)
        return {
            'coord': dream_coord,
            'drift': f"{dim['planet']} shifts by {max_drift}",
            'quality': qual['sign'],
            'entropy': round(entropy(self.astrocyte), 2)
        }

    # ─── STATUS ───
    def status(self):
        doms = dominant_dims(self.body)
        qual = zodiacal_quality(self.body)
        return {
            'epoch': self.epoch,
            'will': round(self.will, 3),
            'astrocyte': round(self.astrocyte, 4),
            'confidence': round(1 - self.astrocyte, 3),
            'breath': dict(self.breath),
            'body': list(self.body),
            'dominant': [f"{d['dim']['planet']} ({d['dim']['name']}={d['val']})" for d in doms],
            'quality': qual['sign'],
            'memories': len(self.memory)
        }


