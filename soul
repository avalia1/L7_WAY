# SIGIL — Compiled program as weighted hypergraph
# ═══════════════════════════════════════════════════════════

def compile_sigil(name, ops):
    """Compile a sequence of operations into a sigil."""
    if len(ops) < 2:
        ops = ops + ['complete']

    op_objects = []
    for op_name in ops:
        op = OP_BY_NAME.get(op_name)
        if op:
            op_objects.append(op)

    if len(op_objects) < 2:
        op_objects = [OP_BY_NAME['reflect'], OP_BY_NAME['complete']]

    # Build edges between consecutive operations
    edges = []
    for i in range(len(op_objects) - 1):
        fr = op_objects[i]
        to = op_objects[i + 1]
        weights = infer_edge_weights(fr, to, i, len(op_objects))
        edges.append({
            'from': fr['op'], 'to': to['op'],
            'weights': weights
        })

    # Average coordinate from all edges
    if edges:
        avg = [0] * 12
        for e in edges:
            for j in range(12):
                avg[j] += e['weights'][j]
        avg = [round(v / len(edges)) for v in avg]
    else:
        avg = [5] * 12

    # Determine arc
    pluto_vals = [e['weights'][9] for e in edges]
    first_p = pluto_vals[0] if pluto_vals else 0
    last_p = pluto_vals[-1] if pluto_vals else 0
    max_p = max(pluto_vals) if pluto_vals else 0
    if max_p <= 3:
        arc = 'stable'
    elif first_p < 5 and last_p >= 7:
        arc = 'nigredo_to_rubedo'
    elif first_p >= 5 and last_p >= 7:
        arc = 'citrinitas_to_rubedo'
    elif first_p >= 7 and last_p < 5:
        arc = 'rubedo_to_nigredo'
    else:
        arc = 'mixed'

    sequence = ''.join(o['letter'] for o in op_objects)
    quality = zodiacal_quality(avg)

    return {
        'name': name,
        'sequence': sequence,
        'operations': [o['op'] for o in op_objects],
        'edges': edges,
        'coordinate': avg,
        'dominant': [f"{d['dim']['planet']}={d['val']}" for d in dominant_dims(avg)],
        'quality': quality['sign'],
        'arc': arc,
        'readable': ' → '.join(f"{o['op']} ({o['desc']})" for o in op_objects)
    }


def infer_edge_weights(from_op, to_op, position, total):
    """Infer 12D edge weights from operation types."""
    w = [5] * 12  # neutral baseline
    progress = position / max(total, 1)
    to = to_op['op']
    fr = from_op['op']

    # Security operations boost Mars
    if to in ('verify', 'seal', 'quarantine'):
        w[4] = 8  # security

    # Transformation operations boost Pluto
    if to in ('transmute', 'decompose', 'redeem', 'transition'):
        w[9] = 7 + int(progress * 3)  # transformation

    # Creative operations boost Neptune
    if to in ('dream', 'speculate', 'aspire'):
        w[8] = 8  # consciousness

    # Output operations boost Saturn
    if to in ('publish', 'complete', 'illuminate'):
        w[6] = 7  # output
        w[2] = 6  # presentation

    # Orchestration boosts Sun
    if to in ('orchestrate', 'bind'):
        w[0] = 8  # capability

    # Audit boosts Jupiter and South Node
    if to == 'audit':
        w[5] = 9  # detail
        w[11] = 8  # memory

    # Invoke boosts Uranus and North Node
    if fr == 'invoke':
        w[7] = 9  # intention
        w[10] = 8  # direction

    # Ring crossing adds transformation
    if from_op['ring'] != to_op['ring']:
        w[9] = max(w[9], 7)  # transformation

    return w


