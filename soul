# ═══════════════════════════════════════════════════════════
# DODECAHEDRON — 12D coordinate math
# ═══════════════════════════════════════════════════════════

def make_coord(weights=None):
    """Create a 12D coordinate from named weights. Values 0-10."""
    coord = [5] * 12  # neutral baseline
    if weights:
        for name, val in weights.items():
            d = DIM_BY_NAME.get(name)
            if d:
                coord[d['i']] = max(0, min(10, int(val)))
    return coord

def cosine_similarity(a, b):
    """Cosine similarity between two 12D vectors. Returns 0-1."""
    dot = sum(x * y for x, y in zip(a, b))
    mag_a = math.sqrt(sum(x * x for x in a))
    mag_b = math.sqrt(sum(x * x for x in b))
    if mag_a == 0 or mag_b == 0:
        return 0.0
    return dot / (mag_a * mag_b)

def euclidean_distance(a, b):
    return math.sqrt(sum((x - y) ** 2 for x, y in zip(a, b)))

def dominant_dims(coord, threshold=7):
    """Dimensions at or above threshold, sorted by value desc."""
    return sorted(
        [{'dim': DIMENSIONS[i], 'val': v} for i, v in enumerate(coord) if v >= threshold],
        key=lambda x: -x['val']
    )

def zodiacal_quality(coord):
    """Zodiac quality based on strongest dimension."""
    doms = sorted(enumerate(coord), key=lambda x: -x[1])
    if doms:
        return ZODIAC[doms[0][0] % 12]
    return ZODIAC[0]

def gaussian_sample(mean, sigma):
    """Box-Muller transform for gaussian noise."""
    u1 = max(random.random(), 0.001)
    u2 = random.random()
    return mean + math.sqrt(-2 * math.log(u1)) * math.cos(2 * math.pi * u2) * sigma

def sample_coord(coord, astrocyte):
    """Sample a concrete coordinate from a probabilistic one."""
    if astrocyte == 0:
        return list(coord)
    sigma = astrocyte * 3
    return [max(0, min(10, round(gaussian_sample(v, sigma)))) for v in coord]

def entropy(astrocyte):
    """Information entropy in bits."""
    if astrocyte <= 0:
        return 0.0
    return math.log2(1 + astrocyte * 10) * 12

def psi_squared(position, point, astrocyte):
    """Wave function probability density |ψ|² at a point."""
    if astrocyte == 0:
        return 1.0 if euclidean_distance(position, point) < 0.5 else 0.0
    sigma = astrocyte * 3
    sigma2 = sigma * sigma
    exponent = sum((p - q) ** 2 for p, q in zip(point, position))
    return math.exp(-exponent / (2 * sigma2))


